CRUSTDATA_API_KEY=
OPENAI_API_KEY=

# Optional: override the OpenAI model used for every structured generation
# (thesis extraction, counterpart rerank, founder synthesis, portfolio HTML
# extraction). Defaults to gpt-5.4-mini for a fast hackathon-grade run; set
# to gpt-5.4 for higher-quality reasoning at ~3-5x latency.
MIRRORVC_LLM_MODEL=gpt-5.4-mini

# Optional: max concurrent OpenAI calls per pipeline step. Default 8.
MIRRORVC_LLM_CONCURRENCY=8
